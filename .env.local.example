# Portkey（単一 API キーで全 LLM を利用）
# https://portkey.ai/docs/integrations/libraries/vercel
PORTKEY_API_KEY=your_portkey_api_key_here

# Portkey → Configs 一覧の ID 列（pc-xxxxx 形式。@ は付けない）
# モデル・フォールバックは Config 側で定義
PORTKEY_CONFIG_STRUCTURING=pc-xxxxx
PORTKEY_CONFIG_SOLVING=pc-yyyyy

# 任意: SDK 用プレースホルダー（Config の override_params が実モデルを決定）
# PORTKEY_MODEL_PLACEHOLDER=gpt-4o-mini

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
