# Google Gemini API Key
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key_here

# OpenAI API Key for GPT-4o-mini
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for future hybrid use)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek API Key (for future hybrid use)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Application Mode Configuration (single = household, multi = public SaaS)
APP_MODE=single
ENABLE_SIGNUP=false

# Client-accessible env vars (must match above for consistency on client-side)
NEXT_PUBLIC_APP_MODE=single
NEXT_PUBLIC_ENABLE_SIGNUP=false

# Default Admin Configuration (for single mode auto-initialization)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=your_secure_admin_password_here

# Publish Workflow Secret (Shared secret for cross-instance publishing JWT/HMAC)
PUBLISH_SHARED_SECRET=your_publish_shared_secret_here

# Feature Flags (Optional JSON representation)
FEATURE_FLAGS_JSON={}

